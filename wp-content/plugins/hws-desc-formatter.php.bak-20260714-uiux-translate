    }

    public static function ajax_status(): void {
        check_ajax_referer('hws_formatter');
        if (!current_user_can('manage_woocommerce')) {
            wp_die('Нет прав.');
        }

        $mode = self::requested_mode();
        $meta_key = self::meta_key_for_mode($mode);

        if (!empty($_POST['reset'])) {
            global $wpdb;
            $wpdb->delete($wpdb->postmeta, ['meta_key' => $meta_key]);
        }

        $total = (int) wp_count_posts('product')->publish;
        $processed = (int) (new WP_Query([
            'post_type' => 'product',
            'post_status' => 'publish',
            'posts_per_page' => -1,
            'fields' => 'ids',
            'meta_query' => [[
                'key' => $meta_key,
                'compare' => 'EXISTS',
            ]],
            'no_found_rows' => false,
        ]))->found_posts;

        wp_send_json_success([
            'total' => $total,
            'processed' => $processed,
        ]);
    }

    public static function ajax_next(): void {
        check_ajax_referer('hws_formatter');
        if (!current_user_can('manage_woocommerce')) {
            wp_die('Нет прав.');
        }

        $mode = self::requested_mode();
        $meta_key = self::meta_key_for_mode($mode);

        $query = new WP_Query([
            'post_type' => 'product',
            'post_status' => 'publish',
            'posts_per_page' => 1,
            'fields' => 'ids',
            'orderby' => 'ID',
            'order' => 'ASC',
            'meta_query' => [[
                'key' => $meta_key,
                'compare' => 'NOT EXISTS',
            ]],
        ]);

        if (empty($query->posts)) {
            wp_send_json_success(['done' => true]);
        }

        $product_id = (int) $query->posts[0];
        $post = get_post($product_id);

        if (!$post instanceof WP_Post) {
            update_post_meta($product_id, $meta_key, 'error');
            wp_send_json_success([
                'done' => false,
                'id' => $product_id,
                'title' => 'unknown',
                'error' => 'Товар не найден',
            ]);
        }

        $title = $post->post_title;
        $settings = self::settings();
        $api_key = $settings['api_key'] ?? '';
        $model = $settings['model'] ?? 'meta-llama/llama-3.1-8b-instruct:free';

        if (!$api_key) {
            wp_send_json_error('API ключ не задан');
        }

        if ($mode === 'format') {
            $result = self::process_format($post, $api_key, $model);
        } else {
            $from_lang = self::request_string('from_lang', $settings['translate_from'] ?? '');
            $to_lang = self::request_string('to_lang', $settings['translate_to'] ?? '');
            $result = self::process_translate($post, $api_key, $model, $from_lang, $to_lang);
        }

        if (!empty($result['mark'])) {
            update_post_meta($product_id, $meta_key, $result['mark']);
        }

        wp_send_json_success([
            'done' => false,
            'id' => $product_id,
            'title' => $title,
            'skipped' => !empty($result['skipped']),
            'skipped_reason' => $result['skipped_reason'] ?? '',
            'error' => $result['error'] ?? '',
        ]);
    }

